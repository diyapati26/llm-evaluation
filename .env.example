# ── LLM Provider API Keys ──────────────────────────────────────────
# Copy this file to .env and fill in your own keys

# OpenAI — required for GPT-5.4-mini and LLM Judge scoring
# Get your key: https://platform.openai.com/api-keys
# Estimated cost for full project run: ~$1-2
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic — required for Claude Sonnet 4.6
# Get your key: https://console.anthropic.com/
# Estimated cost for full project run: ~$0.50-1.50
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Groq — required for Llama 4 Scout (completely free)
# Get your key: https://console.groq.com/keys
# No billing required — free tier is sufficient
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter — optional, gateway to 200+ models (Anthropic, OpenAI, Meta, Mistral, DeepSeek, Qwen, xAI, etc.)
# Get your key: https://openrouter.ai/keys
# Pricing varies per model — see https://openrouter.ai/models. Live prices fetched at runtime.
OPENROUTER_API_KEY=your_openrouter_api_key_here

